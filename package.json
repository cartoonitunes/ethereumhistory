{
  "name": "ethereumhistory",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "echo 'Migrations skipped in postbuild. Run npm run db:migrate manually when schema changes.'",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:import": "npx tsx scripts/import-data.ts",
    "db:similarity": "npx tsx scripts/build-similarity-index.ts",
    "db:capabilities:beta": "npx tsx scripts/backfill-capabilities-beta.ts --max=200",
    "db:capabilities:beta:full": "npx tsx scripts/backfill-capabilities-beta.ts --full",
    "similarity:run": "cd pipeline && python -m similarity.main"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@react-sigma/core": "^5.0.6",
    "@tailwindcss/typography": "^0.5.15",
    "@types/d3": "^7.4.3",
    "@vercel/analytics": "^1.6.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.2.10",
    "graphology": "^0.26.0",
    "graphology-layout-force": "^0.2.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-types": "^0.24.8",
    "lucide-react": "^0.378.0",
    "next": "16.1.4",
    "postgres": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "sevm": "^0.7.4",
    "sigma": "^3.0.2",
    "viem": "^2.45.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
